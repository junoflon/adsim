# ===== LLM 설정 (Anthropic Claude) =====
# https://console.anthropic.com/settings/keys 에서 발급
LLM_API_KEY=sk-ant-your-api-key-here
LLM_MODEL_NAME=claude-sonnet-4-5

# ===== Zep 메모리 그래프 설정 =====
# https://app.getzep.com/ 에서 무료 발급
ZEP_API_KEY=your_zep_api_key_here

# ===== 가속 LLM 설정 (선택) =====
# 빠른/저렴한 모델로 보조 처리하고 싶을 때
# LLM_BOOST_API_KEY=
# LLM_BOOST_MODEL_NAME=claude-haiku-4-5
